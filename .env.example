# ── Database (required) ───────────────────────
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLDATABASE=kikedev
MYSQLUSER=root
MYSQLPASSWORD=

# ── Session (required) ───────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# ── Admin CRM credentials (required for CRM login) ──
ADMIN_USER=
ADMIN_PASS=

# ── Email notifications (optional) ───────────
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# ── App URL (used in email links) ────────────
APP_URL=https://yourdomain.com

# ── CORS (comma-separated allowed origins, optional) ──
CORS_ORIGIN=https://yourdomain.com

# ── Environment ──────────────────────────────
NODE_ENV=production
PORT=3000
